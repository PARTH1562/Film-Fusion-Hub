  background: var(--color-bg-alt);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  max-width: 400px;
  width: 100%;
  text-align: center;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-lg);
}

.subscribe-card__header {
  margin-bottom: var(--spacing-lg);
}

.subscribe-card__title {
  font-size: 2rem;
  color: var(--color-primary);
  margin-bottom: var(--spacing-xs);
}

.subscribe-card__price {
  font-size: 3rem;
  font-weight: 800;
  margin-bottom: var(--spacing-lg);
}

.subscribe-card__price .currency {
  font-size: 1.5rem;
  vertical-align: super;
}

.subscribe-card__price .period {
  font-size: 1rem;
  color: var(--color-text-muted);
  font-weight: 400;
}

.subscribe-card__features {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--spacing-xl) 0;
  text-align: left;
}

.subscribe-card__features li {
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.subscribe-card__features i {
  color: #4CAF50;
}

.subscribe-card__footer {
  margin-top: var(--spacing-md);
  font-size: 0.85rem;
  color: var(--color-text-muted);
}
</style>
