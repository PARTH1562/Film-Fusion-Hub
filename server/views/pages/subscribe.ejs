<section class="subscribe-section container">
  <div class="subscribe-card">
    <div class="subscribe-card__header">
      <h2 class="subscribe-card__title">FilmFusion Premium</h2>
      <p class="subscribe-card__subtitle">Experience cinema like never before</p>
    </div>

    <div class="subscribe-card__price">
      <span class="currency">₹</span>
      <span class="amount">99</span>
      <span class="period">/ month</span>
    </div>

    <ul class="subscribe-card__features">
      <li><i class="fas fa-check"></i> Exclusive Premium Badge</li>
      <li><i class="fas fa-check"></i> Private Discussions</li>
      <li><i class="fas fa-check"></i> Interactive Community Polls</li>
      <li><i class="fas fa-check"></i> Top Reviewers Club Access</li>
      <li><i class="fas fa-check"></i> Priority Support</li>
      <li><i class="fas fa-check"></i> Ad-free Experience</li>
    </ul>

    <button id="rzp-button" class="btn btn--primary btn--large btn--block">
      Pay with Razorpay / UPI
    </button>
    
    <p class="subscribe-card__footer">
      Safe & Secure checkout powered by Razorpay.
    </p>
  </div>
</section>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
document.getElementById('rzp-button').onclick = async function(e) {
  e.preventDefault();

  try {
    // 1. Create Order on Backend
    const res = await fetch('/api/subscriptions/create-order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    
    const order = await res.json();
    if (!res.ok) throw new Error(order.message || 'Failed to create order');

    // 2. Handle Mock Order (if keys are placeholders)
    if (order.id.startsWith('order_mock_')) {
      const verifyRes = await fetch('/api/subscriptions/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ razorpay_order_id: order.id })
      });
      const verifyData = await verifyRes.json();
      if (verifyData.ok) {
        alert('Mock Payment Successful! (Using developer placeholders)');
        window.location.href = '/profile';
      }
      return;
    }

    // 3. Open Razorpay Checkout (Real mode)
    const options = {
      key: order.key,
      amount: order.amount,
      currency: order.currency,
      name: "FilmFusion",
      description: "Premium Subscription",
      order_id: order.id,
      handler: async function (response) {
        // 3. Verify Payment on Backend
        const verifyRes = await fetch('/api/subscriptions/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpay_order_id: response.razorpay_order_id,
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_signature: response.razorpay_signature
          })
        });

        const verifyData = await verifyRes.json();
        if (verifyData.ok) {
          alert('Subscription successful! Redirecting to profile...');
          window.location.href = '/profile';
        } else {
          alert('Payment verification failed: ' + verifyData.message);
        }
      },
      prefill: {
        name: "<%= currentUser.name %>",
        email: "<%= currentUser.email %>"
      },
      theme: {
        color: "#E50914"
      }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  } catch (err) {
    console.error(err);
    alert('Error: ' + err.message);
  }
};
</script>

<style>
